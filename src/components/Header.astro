---
// src/components/Header.astro
import Logo from "../assets/logo1.png";
---

<header id="site-header">

  <!-- Barra superior decorativa -->
  <div class="top-bar" id="top-bar">
    <span class="top-bar-text">🌿 Comprometidos con el ambiente y el futuro del planeta</span>
    <div class="top-bar-divider"></div>
    <a href="mailto:contacto@tuempresa.com" class="top-bar-contact">aurora.ambiente@gmail.com</a>
  </div>

  <!-- Cuerpo principal del header -->
  <div class="header-main" id="header-main">
    <a href="#inicio" class="logo">
      <img src={Logo.src} alt="Logo" class="img-logo" />
      <div class="logo-text">
        <span class="logo-mark">◆</span>
        <span class="logo-name">Expertos en<br/>ambiente y cambio climático.</span>
      </div>
    </a>

    <nav id="main-nav">
      <a href="#inicio">Inicio</a>
      <a href="#servicios">Servicios</a>
      <a href="#about">Nosotros</a>
      <a href="#contacto">Contacto</a>
    </nav>

    <div class="header-actions">
      <a href="#contacto" class="nav-cta">
        <span>Hablar con nosotros</span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M1 6h10M6 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <button id="menu-toggle" class="mobile-menu" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

</header>

<style>
  /* ── VARIABLES ── */
  :root {
    --green-deep:    #1a3a2a;
    --green-mid:     #2d6a4f;
    --green-light:   #52b788;
    --green-pale:    #d8f3dc;
    --top-bar-h:     36px;
    --header-main-h: 154px;
    --header-total:  190px;
  }

  /* ── HEADER WRAPPER ── */
  header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.4s ease;
  }
  header.scrolled {
    box-shadow: 0 4px 40px rgba(26, 58, 42, 0.13);
  }
  header.scrolled .top-bar {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  /* ── TOP BAR ── */
  .top-bar {
    width: 100%;
    max-height: var(--top-bar-h);
    background: var(--green-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 0 48px;
    overflow: hidden;
    flex-shrink: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease, padding 0.4s ease;
  }
  .top-bar-text {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: rgba(216, 243, 220, 0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .top-bar-divider {
    width: 1px;
    height: 14px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }
  .top-bar-contact {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--green-light);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .top-bar-contact:hover { color: white; }

  /* ── HEADER MAIN ── */
  .header-main {
    height: var(--header-main-h);
    background: rgba(247, 247, 245, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(45, 106, 79, 0.15);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    position: relative;
    gap: 16px;
  }
  .header-main::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg, var(--green-mid) 0%, var(--green-light) 50%, transparent 100%);
    opacity: 0.6;
  }

  /* ── LOGO ── */
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
    max-width: 380px;
  }
  .img-logo {
    width: 100px;
    height: auto;
    object-fit: contain;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .logo:hover .img-logo { transform: scale(1.03); }
  .logo-text {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    min-width: 0;
  }
  .logo-mark {
    color: var(--green-light);
    font-size: 0.65rem;
    margin-top: 5px;
    flex-shrink: 0;
  }
  .logo-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--green-deep);
    letter-spacing: 0.02em;
    line-height: 1.35;
    white-space: normal;
    word-break: break-word;
  }

  /* ── NAV DESKTOP ── */
  nav {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-shrink: 0;
  }
  nav a {
    text-decoration: none;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4a6155;
    transition: color 0.2s;
    position: relative;
    padding-bottom: 3px;
    white-space: nowrap;
  }
  nav a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
    width: 0; height: 1.5px;
    background: var(--green-light);
    border-radius: 2px;
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  nav a:hover { color: var(--green-deep); }
  nav a:hover::after { width: 100%; }

  /* ── HEADER ACTIONS ── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  /* ── CTA ── */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    text-decoration: none;
    padding: 11px 20px;
    background: var(--green-mid);
    border: 1.5px solid var(--green-mid);
    border-radius: 2px;
    white-space: nowrap;
    transition: background 0.25s, border-color 0.25s, gap 0.25s;
  }
  .nav-cta:hover {
    background: var(--green-deep);
    border-color: var(--green-deep);
    gap: 12px;
  }
  .nav-cta svg { flex-shrink: 0; }

  /* ── BURGER ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: none;
    border: 1px solid rgba(45, 106, 79, 0.25);
    border-radius: 4px;
    cursor: pointer;
    padding: 8px;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .mobile-menu:hover { background: var(--green-pale); border-color: var(--green-light); }
  .mobile-menu span {
    display: block;
    height: 1.5px;
    background: var(--green-deep);
    border-radius: 2px;
    transform-origin: center;
    transition:
      transform 0.38s cubic-bezier(0.16, 1, 0.3, 1),
      opacity   0.25s ease,
      width     0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mobile-menu span:nth-child(1) { width: 20px; }
  .mobile-menu span:nth-child(2) { width: 14px; }
  .mobile-menu span:nth-child(3) { width: 20px; }

  .mobile-menu.is-open { background: var(--green-pale); border-color: var(--green-light); }
  .mobile-menu.is-open span:nth-child(1) { width: 20px; transform: translateY(6.5px) rotate(45deg); }
  .mobile-menu.is-open span:nth-child(2) { opacity: 0; width: 0; }
  .mobile-menu.is-open span:nth-child(3) { width: 20px; transform: translateY(-6.5px) rotate(-45deg); }

  /* ── TABLET 1024px ── */
  @media (max-width: 1024px) {
    .header-main { padding: 0 28px; gap: 12px; }
    .top-bar { padding: 0 28px; }
    .nav-cta span { display: none; }
    .nav-cta { padding: 10px 12px; gap: 0; }
    nav { gap: 20px; }
    .logo-name { font-size: 0.9rem; }
  }

  /* ── TABLET CHICO 860px ── */
  @media (max-width: 860px) {
    .logo-name { display: none; }
    .logo-mark { display: none; }
    .logo-text { display: none; }
    nav { gap: 16px; }
  }

  /* ── MOBILE 768px ── */
  @media (max-width: 768px) {
    .top-bar { display: none; }
    .header-main {
      padding: 0 20px;
      height: var(--header-main-h);
      /* En mobile el header-main es más compacto */
      height: 80px;
    }

    /* Mostramos logo-text de nuevo en mobile con tamaño adaptado */
    .logo-text { display: flex; }
    .logo-mark { display: block; font-size: 0.55rem; margin-top: 4px; }
    .logo-name {
      display: block;
      font-size: 0.78rem;
      line-height: 1.3;
      max-width: 160px;
    }
    .img-logo { width: 56px; }
    .logo { gap: 8px; max-width: unset; }

    .nav-cta { display: none; }
    .mobile-menu { display: flex; }

    /* Ocultamos nav desktop */
    nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      position: fixed;
      left: 0;
      right: 0;
      top: 80px; /* se sobreescribe por JS */
      background: white;
      /* Sin borde superior — solo borde inferior sutil */
      border-top: none;
      border-bottom: 1px solid var(--green-pale);
      overflow: hidden;
      z-index: 998;

      /* CERRADO */
      max-height: 0;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-4px);
      transition:
        max-height 0.46s cubic-bezier(0.16, 1, 0.3, 1),
        opacity    0.32s cubic-bezier(0.16, 1, 0.3, 1),
        transform  0.38s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ABIERTO */
    nav.is-open {
      max-height: 400px;
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    /* Links mobile */
    nav a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #4a6155;
      padding: 20px 24px;
      border-bottom: 1px solid var(--green-pale);
      opacity: 0;
      transform: translateY(-5px);
      transition:
        opacity    0.26s ease,
        transform  0.26s ease,
        color      0.2s,
        background 0.2s;
    }
    nav a::after { display: none; }
    nav a::before {
      content: '◆';
      font-size: 0.38rem;
      color: var(--green-light);
      opacity: 0;
      transform: scale(0) rotate(-90deg);
      transition: opacity 0.2s, transform 0.25s cubic-bezier(0.16,1,0.3,1);
    }
    nav a:hover { color: var(--green-deep); background: var(--green-pale); }
    nav a:hover::before { opacity: 1; transform: scale(1) rotate(0deg); }
    nav a:last-child { border-bottom: none; }

    nav.is-open::after {
      content: 'Hablar con nosotros →';
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 18px 24px;
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--green-mid);
      font-weight: 500;
      background: var(--green-pale);
      opacity: 0;
      animation: ctaFade 0.3s ease 0.36s forwards;
    }
    @keyframes ctaFade { to { opacity: 1; } }

    nav.is-open a:nth-child(1) { opacity:1; transform:translateY(0); transition-delay:0.07s; }
    nav.is-open a:nth-child(2) { opacity:1; transform:translateY(0); transition-delay:0.14s; }
    nav.is-open a:nth-child(3) { opacity:1; transform:translateY(0); transition-delay:0.21s; }
    nav.is-open a:nth-child(4) { opacity:1; transform:translateY(0); transition-delay:0.28s; }
  }

  /* ── MÓVILES PEQUEÑOS 400px ── */
  @media (max-width: 400px) {
    .img-logo { width: 46px; }
    .logo-name { font-size: 0.7rem; max-width: 130px; }
    .header-main { padding: 0 14px; }
  }
</style>

<script>
  const header     = document.getElementById('site-header')!;
  const nav        = document.getElementById('main-nav')!;
  const toggle     = document.getElementById('menu-toggle')!;

  /* Calcula el top del nav según altura real del header en ese momento */
  function setNavTop() {
    const h = header.getBoundingClientRect().height;
    nav.style.top = h + 'px';
  }

  /* Scroll → sombra + recalcular top del nav */
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 20);
    setTimeout(setNavTop, 420);
  });

  /* Inicializar al cargar */
  setNavTop();
  window.addEventListener('resize', setNavTop);

  /* Toggle menú */
  toggle.addEventListener('click', () => {
    setNavTop();
    const isOpen = nav.classList.toggle('is-open');
    toggle.classList.toggle('is-open', isOpen);
    toggle.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  /* Cerrar al tocar un link */
  nav.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle.classList.remove('is-open');
      toggle.setAttribute('aria-label', 'Abrir menú');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>