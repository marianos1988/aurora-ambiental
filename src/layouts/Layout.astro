<!doctype html>
<html lang="en">
	<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Parallax Pro Astro</title>
    <style>
      :root {
        --primary: #00bfff;
        --secondary: #ffffff;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        scroll-behavior: smooth;
        font-family: Arial, sans-serif;
      }

      body {
        background: var(--secondary);
        color: #333;
      }

      main {
        margin-top: 80px;
      }

      .fade-in {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s ease;
      }

      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (max-width: 768px) {
        nav {
          display: none;
        }

        .mobile-menu {
          display: block;
          cursor: pointer;
		  color: #000;
        }

        .menu-open nav {
          display: flex;
          position: absolute;
          top: 60px;
          right: 0;
          background: white;
          flex-direction: column;
          padding: 20px;
        }
      }
    </style>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
