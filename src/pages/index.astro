---
// src/pages/index.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aurora Ambiental — Consultora en Ambiente y Cambio Climático</title>
    <meta name="description" content="Consultora especializada en ambiente y cambio climático. Asesoramiento técnico-ambiental para organizaciones." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      /* ── VARIABLES GLOBALES ── */
      :root {
        --green-deep:   #1a3a2a;
        --green-mid:    #2d6a4f;
        --green-light:  #52b788;
        --green-pale:   #d8f3dc;
        --ink:          #111110;
        --muted:        #5a6b60;
        --border:       #d4e4d8;
        --bg:           #f4f8f5;
        --white:        #ffffff;
        --accent:       #52b788;
        --header-total: 190px;
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        font-weight: 300;
        line-height: 1.6;
        overflow-x: hidden;
      }

      main { padding-top: var(--header-total); }

      /* ── REVEAL ── */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.9s cubic-bezier(.16,1,.3,1), transform 0.9s cubic-bezier(.16,1,.3,1);
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-delay-1 { transition-delay: 0.10s; }
      .reveal-delay-2 { transition-delay: 0.22s; }
      .reveal-delay-3 { transition-delay: 0.34s; }
      .reveal-delay-4 { transition-delay: 0.46s; }

      /* ── SHARED SECTION STYLES ── */
      .section-label {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-light);
        margin-bottom: 14px;
        display: block;
      }
      .section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2rem, 3.5vw, 3rem);
        font-weight: 300;
        line-height: 1.12;
        color: var(--green-deep);
      }
      .section-title em { font-style: italic; color: var(--green-light); }

      /* ── BOTONES ── */
      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--green-mid);
        color: var(--white);
        padding: 14px 32px;
        font-size: 0.78rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 2px;
        transition: background 0.3s, gap 0.3s;
        width: fit-content;
      }
      .btn-primary:hover { background: var(--green-deep); gap: 16px; }
      .btn-primary svg { width: 13px; height: 13px; }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border: 1px solid rgba(45,106,79,0.35);
        color: var(--green-mid);
        padding: 13px 28px;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-decoration: none;
        border-radius: 2px;
        margin-left: 14px;
        transition: border-color 0.3s, background 0.3s, color 0.3s;
      }
      .btn-ghost:hover { border-color: var(--green-mid); background: var(--green-pale); }

      /* ══════════════════════════════════════
         HERO — #inicio
      ══════════════════════════════════════ */
      #inicio {
        min-height: calc(100vh - var(--header-total));
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .hero-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 80px 56px 80px 72px;
        will-change: transform;
      }

      .hero-eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 28px;
      }
      .hero-eyebrow-line {
        width: 28px;
        height: 1px;
        background: var(--green-light);
      }
      .hero-eyebrow span {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-light);
      }

      .hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.6rem, 4.5vw, 5rem);
        font-weight: 300;
        line-height: 1.08;
        color: var(--green-deep);
        margin-bottom: 28px;
      }
      .hero-title em { font-style: italic; color: var(--green-light); }

      .hero-sub {
        font-size: 0.95rem;
        color: var(--muted);
        max-width: 420px;
        line-height: 1.8;
        margin-bottom: 44px;
      }

      .hero-image {
        position: relative;
        overflow: hidden;
        min-height: 520px;
      }
      .hero-image img {
        width: 100%;
        height: 130%;
        object-fit: cover;
        position: absolute;
        top: -15%;
        left: 0;
        will-change: transform;
        filter: grayscale(10%) saturate(0.9);
      }
      .hero-image::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(26,58,42,0.22) 0%, transparent 60%);
        z-index: 1;
        pointer-events: none;
      }
      .hero-image::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 50%, rgba(26,58,42,0.15) 100%);
        z-index: 1;
        pointer-events: none;
      }

      /* ── STATS BAR ── */
      .stats-bar {
        background: var(--green-deep);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
      }
      .stat-item {
        padding: 40px 36px;
        border-right: 1px solid rgba(255,255,255,0.08);
        text-align: center;
      }
      .stat-item:last-child { border-right: none; }
      .stat-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3rem;
        font-weight: 300;
        color: var(--white);
        line-height: 1;
        margin-bottom: 6px;
      }
      .stat-number span { color: var(--green-light); }
      .stat-label {
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
      }

      /* ══════════════════════════════════════
         SERVICIOS — #servicios
      ══════════════════════════════════════ */
      #servicios {
        padding: 110px 72px;
        background: var(--white);
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 64px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--border);
      }
      .section-link {
        font-size: 0.78rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.06em;
        border-bottom: 1px solid var(--border);
        padding-bottom: 3px;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
      }
      .section-link:hover { color: var(--green-mid); border-color: var(--green-mid); }

      .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
        background: var(--border);
      }
      .service-card {
        background: var(--white);
        padding: 44px 36px;
        transition: background 0.32s, transform 0.32s;
        cursor: default;
      }
      .service-card:hover { background: var(--green-deep); }
      .service-card:hover .service-number,
      .service-card:hover .service-name,
      .service-card:hover .service-desc { color: var(--white); }
      .service-card:hover .service-divider { background: rgba(255,255,255,0.18); }

      .service-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.82rem;
        color: var(--green-light);
        margin-bottom: 24px;
        transition: color 0.32s;
      }
      .service-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.45rem;
        font-weight: 400;
        color: var(--green-deep);
        margin-bottom: 14px;
        transition: color 0.32s;
        line-height: 1.25;
      }
      .service-divider {
        width: 28px;
        height: 1px;
        background: var(--border);
        margin-bottom: 16px;
        transition: background 0.32s;
      }
      .service-desc {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.75;
        transition: color 0.32s;
      }

      /* ── EJES TEMÁTICOS ── */
      #ejes {
        padding: 80px 72px;
        background: var(--green-pale);
      }
      .ejes-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 3px;
        background: rgba(45,106,79,0.15);
        margin-top: 52px;
      }
      .eje-card {
        background: var(--white);
        padding: 40px 36px;
        display: flex;
        align-items: flex-start;
        gap: 20px;
        transition: background 0.3s;
      }
      .eje-card:hover { background: var(--green-pale); }
      .eje-icon {
        font-size: 1.6rem;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .eje-content h3 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.3rem;
        font-weight: 400;
        color: var(--green-deep);
        margin-bottom: 10px;
      }
      .eje-content p {
        font-size: 0.84rem;
        color: var(--muted);
        line-height: 1.7;
      }

      /* ══════════════════════════════════════
         CAROUSEL — #galeria
      ══════════════════════════════════════ */
      #galeria {
        background: var(--green-deep);
        padding: 80px 0 72px;
        overflow: hidden;
        position: relative;
      }

      /* ── Variables internas del carousel ── */
      #galeria {
        --c-pad: 72px;
        --c-gap: 20px;
        --c-visible: 3;
      }

      .galeria-header {
        padding: 0 var(--c-pad);
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 44px;
        gap: 24px;
      }
      .galeria-header .section-label { color: rgba(216,243,220,0.6); }
      .galeria-header .section-title { color: var(--white); }
      .galeria-header .section-title em { color: var(--green-light); }

      /* ── Controles prev/next — diseño circular refinado ── */
      .carousel-controls {
        display: flex;
        gap: 12px;
        flex-shrink: 0;
        align-items: center;
        padding-bottom: 6px;
      }
      .carousel-btn {
        position: relative;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        border: 1.5px solid rgba(255,255,255,0.18);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.65);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
        transition: border-color 0.3s ease, color 0.3s ease, transform 0.25s ease;
      }
      /* Fondo que aparece al hover */
      .carousel-btn::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: var(--green-light);
        transform: scale(0);
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .carousel-btn svg {
        position: relative;
        z-index: 1;
        width: 20px;
        height: 20px;
        transition: transform 0.25s ease;
        stroke-width: 1.8;
      }
      .carousel-btn:hover {
        border-color: var(--green-light);
        color: var(--green-deep);
        transform: scale(1.06);
      }
      .carousel-btn:hover::before { transform: scale(1); }
      .carousel-btn:hover svg { transform: scale(1.1); }
      .carousel-btn:active { transform: scale(0.96); }
      /* Flecha prev: desplaza levemente a la izquierda al hover */
      #prev-btn:hover svg { transform: translateX(-1px) scale(1.1); }
      /* Flecha next: desplaza levemente a la derecha al hover */
      #next-btn:hover svg { transform: translateX(1px) scale(1.1); }

      /* ── Viewport y track ── */
      .carousel-viewport {
        overflow: hidden;
        width: 100%;
        cursor: grab;
        user-select: none;
      }
      .carousel-viewport:active { cursor: grabbing; }

      .carousel-track {
        display: flex;
        gap: var(--c-gap);
        padding: 0 var(--c-pad);
        transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
        will-change: transform;
      }

      /* ── Cada slide ── */
      .carousel-slide {
        flex: 0 0 calc((100% - var(--c-pad) * 2 - var(--c-gap) * (var(--c-visible) - 1)) / var(--c-visible));
        min-width: 0;
        position: relative;
        border-radius: 4px;
        overflow: hidden;
        aspect-ratio: 4 / 3;
      }

      .carousel-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease, filter 0.5s ease;
        filter: saturate(0.85) brightness(0.88);
      }
      .carousel-slide:hover img {
        transform: scale(1.04);
        filter: saturate(1) brightness(0.95);
      }

      /* ── Caption overlay ── */
      .slide-caption {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(26,58,42,0.85) 0%, transparent 55%);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 22px 20px;
        opacity: 0;
        transition: opacity 0.35s ease;
      }
      .carousel-slide:hover .slide-caption { opacity: 1; }

      .slide-caption-label {
        font-size: 0.63rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-light);
        margin-bottom: 5px;
      }
      .slide-caption-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.05rem;
        font-weight: 400;
        color: var(--white);
        line-height: 1.3;
      }

      /* ── Dots ── */
      .carousel-dots {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 36px;
        padding: 0 var(--c-pad);
      }
      .carousel-dot {
        width: 20px;
        height: 3px;
        border-radius: 2px;
        background: rgba(255,255,255,0.2);
        border: none;
        cursor: pointer;
        transition: background 0.3s, width 0.3s;
        padding: 0;
      }
      .carousel-dot.active {
        background: var(--green-light);
        width: 36px;
      }

      /* ══════════════════════════════════════
         NOSOTROS — #about
      ══════════════════════════════════════ */
      #about {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 75vh;
      }

      .about-image {
        position: relative;
        overflow: hidden;
        min-height: 400px;
      }
      .about-image img {
        width: 100%;
        height: 130%;
        object-fit: cover;
        position: absolute;
        top: -15%;
        left: 0;
        will-change: transform;
        filter: grayscale(15%) saturate(0.85);
      }
      .about-image::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, transparent 60%, rgba(244,248,245,0.4) 100%);
        z-index: 1;
        pointer-events: none;
      }

      .about-content {
        padding: 90px 72px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--white);
      }

      .about-quote {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.3rem, 2vw, 1.9rem);
        font-weight: 300;
        font-style: italic;
        color: var(--green-deep);
        line-height: 1.45;
        margin-bottom: 32px;
        padding-left: 24px;
        border-left: 2px solid var(--green-light);
      }

      .about-text {
        font-size: 0.9rem;
        color: var(--muted);
        line-height: 1.85;
        margin-bottom: 36px;
      }

      .about-pillars {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 36px;
      }
      .pillar {
        padding: 18px 20px;
        border: 1px solid var(--border);
        border-radius: 2px;
        transition: border-color 0.2s, background 0.2s;
      }
      .pillar:hover { border-color: var(--green-light); background: var(--green-pale); }
      .pillar h4 {
        font-size: 0.68rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--green-light);
        margin-bottom: 8px;
        font-weight: 500;
      }
      .pillar p {
        font-size: 0.82rem;
        color: var(--muted);
        line-height: 1.6;
      }

      .about-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .tag {
        padding: 6px 16px;
        border: 1px solid var(--border);
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        border-radius: 2px;
        transition: all 0.2s;
      }
      .tag:hover { border-color: var(--green-mid); color: var(--green-mid); background: var(--green-pale); }

      /* ── EQUIPO ── */
      #equipo {
        padding: 100px 72px;
        background: var(--bg);
      }
      .team-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        margin-top: 56px;
      }
      .team-card {
        background: var(--white);
        border: 1px solid var(--border);
        padding: 36px 28px;
        text-align: center;
        border-radius: 2px;
        transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
      }
      .team-card:hover {
        border-color: var(--green-light);
        box-shadow: 0 8px 32px rgba(26,58,42,0.08);
        transform: translateY(-4px);
      }
      .team-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--green-pale);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin: 0 auto 18px;
        border: 2px solid var(--green-light);
      }
      .team-role {
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--green-light);
        margin-bottom: 6px;
      }
      .team-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--green-deep);
      }

      /* ══════════════════════════════════════
         CONTACTO — #contacto
      ══════════════════════════════════════ */
      #contacto {
        padding: 110px 72px;
        background: var(--white);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 88px;
        align-items: start;
      }

      .contact-intro .section-title { margin-bottom: 24px; }
      .contact-intro > p {
        font-size: 0.9rem;
        color: var(--muted);
        line-height: 1.8;
        margin-bottom: 36px;
      }
      .contact-detail {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 16px;
        font-size: 0.86rem;
        color: var(--muted);
      }
      .contact-detail-icon {
        width: 34px;
        height: 34px;
        background: var(--green-pale);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
      }
      .contact-detail strong { color: var(--green-deep); font-weight: 500; display: block; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1px; }

      .contact-form { display: flex; flex-direction: column; gap: 18px; }
      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .form-group { display: flex; flex-direction: column; gap: 7px; }
      .form-group label {
        font-size: 0.68rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .form-group input,
      .form-group textarea,
      .form-group select {
        background: var(--bg);
        border: 1px solid var(--border);
        padding: 13px 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.86rem;
        color: var(--ink);
        outline: none;
        border-radius: 2px;
        transition: border-color 0.2s, background 0.2s;
        appearance: none;
        resize: none;
      }
      .form-group input:focus,
      .form-group textarea:focus,
      .form-group select:focus { border-color: var(--green-light); background: var(--white); }
      .form-group textarea { min-height: 120px; }

      .btn-submit {
        background: var(--green-mid);
        color: var(--white);
        border: none;
        padding: 16px 36px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.78rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        border-radius: 2px;
        align-self: flex-start;
        transition: background 0.3s;
      }
      .btn-submit:hover { background: var(--green-deep); }

      /* ══════════════════════════════════════
         RESPONSIVE
      ══════════════════════════════════════ */
      @media (max-width: 1024px) {
        #inicio { grid-template-columns: 1fr; }
        .hero-image { min-height: 45vh; }
        .hero-text { padding: 60px 40px; }
        #servicios, #ejes, #equipo, #contacto { padding: 80px 40px; }
        .services-grid { grid-template-columns: 1fr 1fr; }
        #about { grid-template-columns: 1fr; }
        .about-image { min-height: 360px; }
        .about-content { padding: 60px 40px; }
        .team-grid { grid-template-columns: repeat(2, 1fr); }
        #contacto { grid-template-columns: 1fr; gap: 56px; }

        /* Carousel tablet — 2 slides visibles */
        #galeria { --c-pad: 40px; --c-gap: 16px; --c-visible: 2; }
      }

