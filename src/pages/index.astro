/* ===== CAROUSEL RESPONSIVE FIX (AUTO-ADDED) ===== */
.carousel-slide {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
  height: clamp(220px, 40vw, 420px);
}

.carousel-slide img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
  background: #000;
  transition: transform 0.6s ease;
}

.carousel-slide:hover img {
  transform: scale(1.05);
}

@media (max-width: 768px) {
  .carousel-track {
    justify-content: center;
  }

  .carousel-slide {
    flex: 0 0 100%;
    max-width: 100%;
  }
}


/* ===== CAROUSEL FIX V2 (NO CROP + TRUE CENTER) ===== */
.carousel-slide {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
  padding: 10px;
  height: auto;
}

.carousel-slide img {
  width: auto;
  height: auto;
  max-width: 100%;
  max-height: 70vh;
  object-fit: contain;
  object-position: center;
}

/* Ensure track alignment */
.carousel-track {
  align-items: center;
}

/* Mobile improvement */
@media (max-width: 768px) {
  .carousel-slide img {
    max-height: 60vh;
  }
}


/* ===== CAROUSEL FIX V3 (IMAGE = CAPTION + MOBILE CENTER) ===== */

/* Slide as positioning context */
.carousel-slide {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #000;
}

/* Image fills exactly like caption */
.carousel-slide img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* fill like caption */
  object-position: center;
}

/* Caption always same size as image */
.slide-caption {
  position: absolute;
  inset: 0;
