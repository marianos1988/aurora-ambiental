---
// src/pages/index.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Empresa — Soluciones que transforman</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --ink:     #111110;
        --muted:   #6b6b67;
        --border:  #e2e2de;
        --bg:      #f7f7f5;
        --white:   #ffffff;
        --accent:  #c8a96e;
        --accent2: #2a2a28;
      }

      *, *::before, *::after {
        margin: 0; padding: 0;
        box-sizing: border-box;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        font-weight: 300;
        line-height: 1.6;
        overflow-x: hidden;
      }

      /* ── REVEAL ANIMATIONS ── */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.9s cubic-bezier(.16,1,.3,1),
                    transform 0.9s cubic-bezier(.16,1,.3,1);
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-delay-1 { transition-delay: 0.1s; }
      .reveal-delay-2 { transition-delay: 0.22s; }
      .reveal-delay-3 { transition-delay: 0.34s; }
      .reveal-delay-4 { transition-delay: 0.46s; }

      /* ── HERO ── */
      #inicio {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding-top: 80px;
      }

      .hero-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 80px 60px 80px 80px;
      }

      .hero-label {
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 28px;
      }

      .hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(3rem, 5vw, 5.5rem);
        font-weight: 300;
        line-height: 1.08;
        color: var(--ink);
        margin-bottom: 32px;
      }

      .hero-title em {
        font-style: italic;
        color: var(--accent);
      }

      .hero-sub {
        font-size: 1rem;
        color: var(--muted);
        max-width: 420px;
        line-height: 1.75;
        margin-bottom: 48px;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: var(--ink);
        color: var(--white);
        padding: 16px 36px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background 0.3s, gap 0.3s;
        width: fit-content;
      }
      .btn-primary:hover { background: var(--accent2); gap: 20px; }
      .btn-primary svg { width: 14px; height: 14px; }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border: 1px solid var(--border);
        color: var(--ink);
        padding: 15px 32px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.06em;
        text-decoration: none;
        transition: border-color 0.3s, background 0.3s;
        margin-left: 16px;
      }
      .btn-ghost:hover { border-color: var(--ink); background: var(--white); }

      .hero-image {
        position: relative;
        overflow: hidden;
      }
      .hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(15%);
        transition: transform 8s ease;
      }
      .hero-image:hover img { transform: scale(1.03); }

      .hero-image::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(200,169,110,0.12) 0%, transparent 60%);
        pointer-events: none;
      }

      /* ── NÚMEROS / STATS ── */
      .stats-bar {
        background: var(--white);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
      }

      .stat-item {
        padding: 44px 40px;
        border-right: 1px solid var(--border);
        text-align: center;
      }
      .stat-item:last-child { border-right: none; }

      .stat-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3.2rem;
        font-weight: 300;
        color: var(--ink);
        line-height: 1;
        margin-bottom: 8px;
      }
      .stat-number span { color: var(--accent); }

      .stat-label {
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      /* ── SERVICIOS ── */
      #servicios {
        padding: 120px 80px;
        background: var(--bg);
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 72px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border);
      }

      .section-label {
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 16px;
      }

      .section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2rem, 3.5vw, 3.2rem);
        font-weight: 300;
        line-height: 1.15;
        color: var(--ink);
        max-width: 480px;
      }

      .section-link {
        font-size: 0.82rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.06em;
        border-bottom: 1px solid var(--border);
        padding-bottom: 4px;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
      }
      .section-link:hover { color: var(--ink); border-color: var(--ink); }

      .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
        background: var(--border);
      }

      .service-card {
        background: var(--white);
        padding: 48px 40px;
        transition: background 0.3s;
        position: relative;
        overflow: hidden;
      }
      .service-card:hover { background: var(--ink); }
      .service-card:hover .service-number,
      .service-card:hover .service-name,
      .service-card:hover .service-desc { color: var(--white); }
      .service-card:hover .service-divider { background: rgba(255,255,255,0.2); }

      .service-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.85rem;
        color: var(--accent);
        margin-bottom: 32px;
        transition: color 0.3s;
      }

      .service-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.6rem;
        font-weight: 400;
        color: var(--ink);
        margin-bottom: 16px;
        transition: color 0.3s;
      }

      .service-divider {
        width: 32px;
        height: 1px;
        background: var(--border);
        margin-bottom: 20px;
        transition: background 0.3s;
      }

      .service-desc {
        font-size: 0.88rem;
        color: var(--muted);
        line-height: 1.75;
        transition: color 0.3s;
      }

      /* ── SOBRE NOSOTROS ── */
      #about {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 80vh;
      }

      .about-image {
        position: relative;
        overflow: hidden;
      }
      .about-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%);
      }

      .about-content {
        padding: 100px 80px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--white);
      }

      .about-quote {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.5rem, 2.5vw, 2.2rem);
        font-weight: 300;
        font-style: italic;
        color: var(--ink);
        line-height: 1.4;
        margin-bottom: 40px;
        padding-left: 28px;
        border-left: 2px solid var(--accent);
      }

      .about-text {
        font-size: 0.92rem;
        color: var(--muted);
        line-height: 1.85;
        margin-bottom: 48px;
      }

      .about-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .tag {
        padding: 8px 18px;
        border: 1px solid var(--border);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        transition: all 0.2s;
      }
      .tag:hover { border-color: var(--ink); color: var(--ink); }

      /* ── CONTACTO ── */
      #contacto {
        padding: 120px 80px;
        background: var(--bg);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 100px;
        align-items: start;
      }

      .contact-intro .section-title {
        max-width: 360px;
        margin-bottom: 28px;
      }

      .contact-intro p {
        font-size: 0.92rem;
        color: var(--muted);
        line-height: 1.8;
        margin-bottom: 40px;
      }

      .contact-detail {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
        font-size: 0.88rem;
        color: var(--muted);
      }
      .contact-detail strong { color: var(--ink); font-weight: 500; }

      .contact-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

      .form-group { display: flex; flex-direction: column; gap: 8px; }

      .form-group label {
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .form-group input,
      .form-group textarea,
      .form-group select {
        background: var(--white);
        border: 1px solid var(--border);
        padding: 14px 18px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.88rem;
        color: var(--ink);
        outline: none;
        transition: border-color 0.2s;
        appearance: none;
        resize: none;
      }
      .form-group input:focus,
      .form-group textarea:focus,
      .form-group select:focus { border-color: var(--ink); }

      .form-group textarea { min-height: 120px; }

      .btn-submit {
        background: var(--ink);
        color: var(--white);
        border: none;
        padding: 18px 40px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.3s;
        align-self: flex-start;
      }
      .btn-submit:hover { background: var(--accent2); }

      /* ── RESPONSIVE ── */
      @media (max-width: 1024px) {
        #inicio, #about { grid-template-columns: 1fr; }
        .hero-image, .about-image { min-height: 45vh; }
        .hero-text { padding: 60px 40px; }
        .about-content { padding: 60px 40px; }
        #servicios { padding: 80px 40px; }
        .services-grid { grid-template-columns: 1fr 1fr; }
        #contacto { grid-template-columns: 1fr; gap: 60px; padding: 80px 40px; }
      }

      @media (max-width: 640px) {
        .hero-text { padding: 50px 24px; }
        .stats-bar { grid-template-columns: 1fr; }
        .stat-item { border-right: none; border-bottom: 1px solid var(--border); }
        .services-grid { grid-template-columns: 1fr; }
        .section-header { flex-direction: column; align-items: flex-start; gap: 24px; }
        #servicios, #contacto { padding: 60px 24px; }
        .form-row { grid-template-columns: 1fr; }
        .about-content { padding: 50px 24px; }
      }
    </style>
  </head>

  <body>
    <Header />

    <main>

      <!-- HERO -->
      <section id="inicio">
        <div class="hero-text">
          <p class="hero-label reveal">Empresa · Innovación · Resultados</p>
          <h1 class="hero-title reveal reveal-delay-1">
            Construimos el<br/><em>futuro</em> de<br/>tu negocio
          </h1>
          <p class="hero-sub reveal reveal-delay-2">
            Soluciones estratégicas que combinan visión, tecnología y ejecución para llevar tu empresa al siguiente nivel.
          </p>
          <div class="reveal reveal-delay-3">
            <a href="#servicios" class="btn-primary">
              Ver servicios
              <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#contacto" class="btn-ghost">Hablar con nosotros</a>
          </div>
        </div>
        <div class="hero-image">
          <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1200&q=80" alt="Oficina moderna" />
        </div>
      </section>

      <!-- STATS -->
      <div class="stats-bar">
        <div class="stat-item reveal">
          <div class="stat-number">12<span>+</span></div>
          <div class="stat-label">Años de experiencia</div>
        </div>
        <div class="stat-item reveal reveal-delay-1">
          <div class="stat-number">240<span>+</span></div>
          <div class="stat-label">Proyectos completados</div>
        </div>
        <div class="stat-item reveal reveal-delay-2">
          <div class="stat-number">98<span>%</span></div>
          <div class="stat-label">Clientes satisfechos</div>
        </div>
      </div>

      <!-- SERVICIOS -->
      <section id="servicios">
        <div class="section-header reveal">
          <div>
            <p class="section-label">Lo que hacemos</p>
            <h2 class="section-title">Servicios diseñados para crecer</h2>
          </div>
          <a href="#contacto" class="section-link">Ver todos los servicios →</a>
        </div>

        <div class="services-grid">
          <div class="service-card reveal">
            <div class="service-number">01</div>
            <h3 class="service-name">Consultoría Estratégica</h3>
            <div class="service-divider"></div>
            <p class="service-desc">Analizamos tu negocio en profundidad y desarrollamos planes de acción concretos orientados a resultados medibles.</p>
          </div>
          <div class="service-card reveal reveal-delay-1">
            <div class="service-number">02</div>
            <h3 class="service-name">Transformación Digital</h3>
            <div class="service-divider"></div>
            <p class="service-desc">Modernizamos tus procesos integrando tecnología de forma inteligente, sin perder el foco en las personas.</p>
          </div>
          <div class="service-card reveal reveal-delay-2">
            <div class="service-number">03</div>
            <h3 class="service-name">Desarrollo de Marca</h3>
            <div class="service-divider"></div>
            <p class="service-desc">Construimos identidades de marca coherentes y memorables que generan confianza y conexión genuina con tu audiencia.</p>
          </div>
          <div class="service-card reveal reveal-delay-1">
            <div class="service-number">04</div>
            <h3 class="service-name">Gestión de Proyectos</h3>
            <div class="service-divider"></div>
            <p class="service-desc">Coordinamos equipos y recursos con metodologías ágiles para entregar en tiempo, forma y dentro del presupuesto.</p>
          </div>
          <div class="service-card reveal reveal-delay-2">
            <div class="service-number">05</div>
            <h3 class="service-name">Análisis de Datos</h3>
            <div class="service-divider"></div>
            <p class="service-desc">Convertimos datos en decisiones. Dashboards, reportes y modelos predictivos que iluminan el camino a seguir.</p>
          </div>
          <div class="service-card reveal reveal-delay-3">
            <div class="service-number">06</div>
            <h3 class="service-name">Capacitación</h3>
            <div class="service-divider"></div>
            <p class="service-desc">Programas de formación a medida para que tu equipo adquiera las habilidades necesarias en un mundo en constante cambio.</p>
          </div>
        </div>
      </section>

      <!-- SOBRE NOSOTROS -->
      <section id="about">
        <div class="about-image">
          <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1200&q=80" alt="Equipo trabajando" />
        </div>
        <div class="about-content">
          <p class="section-label reveal">Quiénes somos</p>
          <blockquote class="about-quote reveal reveal-delay-1">
            "Creemos que cada empresa tiene el potencial de ser extraordinaria."
          </blockquote>
          <p class="about-text reveal reveal-delay-2">
            Somos un equipo multidisciplinario con más de una década acompañando a empresas en su crecimiento. Combinamos rigor analítico con creatividad para diseñar soluciones que realmente funcionan. No vendemos servicios genéricos — construimos relaciones de largo plazo basadas en resultados concretos.
          </p>
          <div class="about-tags reveal reveal-delay-3">
            <span class="tag">Innovación</span>
            <span class="tag">Confianza</span>
            <span class="tag">Resultados</span>
            <span class="tag">Agilidad</span>
            <span class="tag">Excelencia</span>
          </div>
        </div>
      </section>

      <!-- CONTACTO -->
      <section id="contacto">
        <div class="contact-intro">
          <p class="section-label reveal">Hablemos</p>
          <h2 class="section-title reveal reveal-delay-1">¿Listo para dar el siguiente paso?</h2>
          <p class="reveal reveal-delay-2">
            Contanos sobre tu proyecto y en menos de 48 horas te respondemos con una propuesta inicial sin costo.
          </p>
          <div class="contact-detail reveal reveal-delay-3">
            <strong>Email</strong>
            <span>contacto@tuempresa.com</span>
          </div>
          <div class="contact-detail reveal reveal-delay-3">
            <strong>Teléfono</strong>
            <span>+54 11 1234-5678</span>
          </div>
          <div class="contact-detail reveal reveal-delay-3">
            <strong>Dirección</strong>
            <span>Buenos Aires, Argentina</span>
          </div>
        </div>

        <form class="contact-form reveal reveal-delay-1">
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" placeholder="Tu nombre" />
            </div>
            <div class="form-group">
              <label for="empresa">Empresa</label>
              <input type="text" id="empresa" placeholder="Tu empresa" />
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" placeholder="tu@email.com" />
          </div>
          <div class="form-group">
            <label for="servicio">Servicio de interés</label>
            <select id="servicio">
              <option value="">Seleccioná una opción</option>
              <option>Consultoría Estratégica</option>
              <option>Transformación Digital</option>
              <option>Desarrollo de Marca</option>
              <option>Gestión de Proyectos</option>
              <option>Análisis de Datos</option>
              <option>Capacitación</option>
            </select>
          </div>
          <div class="form-group">
            <label for="mensaje">Mensaje</label>
            <textarea id="mensaje" placeholder="Contanos sobre tu proyecto..."></textarea>
          </div>
          <button type="submit" class="btn-submit">Enviar mensaje</button>
        </form>
      </section>

    </main>

    <Footer />

    <script>
      // Reveal on scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Mobile menu
      const toggle = document.querySelector('#menu-toggle');
      const header:any = document.querySelector('header');
      toggle?.addEventListener('click', () => header.classList.toggle('menu-open'));

      // Parallax suave en hero image
      window.addEventListener('scroll', () => {
        const heroImg:any = document.querySelector('.hero-image img');
        if (heroImg) {
          heroImg.style.transform = `translateY(${window.scrollY * 0.08}px) scale(1.05)`;
        }
      });
    </script>
  </body>
</html>
