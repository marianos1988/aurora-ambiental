    <script>
import { any } from "astro:schema";

      /* ── REVEAL ON SCROLL ── */
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      /* ── PARALLAX ENGINE (rAF + lerp) ── */
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const layers = [
        { selector: '.hero-image img',  speed: 0.28, lerp: 0.07 },
        { selector: '.hero-text',       speed: -0.05, lerp: 0.05 },
        { selector: '.about-image img', speed: 0.30, lerp: 0.07 },
      ];
      const nodes:any = layers.map(l => document.querySelector(l.selector));
      const state = layers.map(() => ({ current: 0, target: 0 }));

      function lerpFn(a:any, b:any, t:any) { return a + (b - a) * t; }

      function tick() {
        layers.forEach((layer, i) => {
          if (!nodes[i]) return;
          state[i].target = window.scrollY * layer.speed;
          state[i].current = lerpFn(state[i].current, state[i].target, layer.lerp);
          if (!prefersReduced) {
            nodes[i].style.transform = `translateY(${state[i].current}px)`;
          }
        });
        requestAnimationFrame(tick);
      }
      if (!prefersReduced) requestAnimationFrame(tick);

      /* ══════════════════════════════════════
         CAROUSEL
      ══════════════════════════════════════ */
      (function initCarousel() {
        const galeria:any    = document.getElementById('galeria');
        const track:any      = document.getElementById('carousel-track');
        const viewport:any   = document.getElementById('carousel-viewport');
        const dotsWrap:any   = document.getElementById('carousel-dots');
        const prevBtn:any    = document.getElementById('prev-btn');
        const nextBtn:any    = document.getElementById('next-btn');

        if (!track) return;

        const slides  = Array.from(track.querySelectorAll('.carousel-slide'));
        const total   = slides.length;
        let current   = 0;
        let autoTimer:any = null;
        let isDragging = false, dragStartX = 0, dragDelta = 0;

        /* ── Leer CSS custom properties del #galeria ── */
        function cssVar(name:any) {
          return parseFloat(getComputedStyle(galeria).getPropertyValue(name)) || 0;
        }

        function visibleCount() {
          const v = cssVar('--c-visible');
          return v > 0 ? Math.round(v) : 3;
        }

        /* ── Offset preciso usando las mismas variables que el CSS ── */
        function getOffset(index:any) {
          const pad  = cssVar('--c-pad');
          const gap  = cssVar('--c-gap');
          const vis  = visibleCount();
          const slideW = (viewport.offsetWidth - pad * 2 - gap * (vis - 1)) / vis;
          return index * (slideW + gap);
        }

        /* ── Ir a slide ── */
        function goTo(index:any, instant = false) {
          const max = Math.max(0, total - visibleCount());
          current = Math.max(0, Math.min(index, max));
          track.style.transition = instant ? 'none' : 'transform 0.55s cubic-bezier(0.4,0,0.2,1)';
          track.style.transform  = `translateX(-${getOffset(current)}px)`;
          updateDots();
        }

        /* ── Dots ── */
        function buildDots() {
          dotsWrap.innerHTML = '';
          const count = Math.max(1, total - visibleCount() + 1);
          for (let i = 0; i < count; i++) {
            const b = document.createElement('button');
            b.className = 'carousel-dot' + (i === 0 ? ' active' : '');
            b.setAttribute('aria-label', `Slide ${i + 1}`);
            b.addEventListener('click', () => { goTo(i); resetAuto(); });
            dotsWrap.appendChild(b);
          }
        }
        function updateDots() {
          dotsWrap.querySelectorAll('.carousel-dot').forEach((d:any, i:any) => d.classList.toggle('active', i === current));
        }

        /* ── Controles ── */
        prevBtn.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
        nextBtn.addEventListener('click', () => { goTo(current + 1); resetAuto(); });

        /* ── Autoplay ── */
        function startAuto() {
          autoTimer = setInterval(() => {
            goTo(current >= total - visibleCount() ? 0 : current + 1);
          }, 4200);
        }
        function resetAuto() { clearInterval(autoTimer); startAuto(); }

        viewport.addEventListener('mouseenter', () => clearInterval(autoTimer));
        viewport.addEventListener('mouseleave', () => { if (!isDragging) startAuto(); });

        /* ── Drag / swipe ── */
        function onStart(x:any) { isDragging = true; dragStartX = x; dragDelta = 0; track.style.transition = 'none'; }
        function onMove(x:any) {
          if (!isDragging) return;
          dragDelta = x - dragStartX;
          track.style.transform = `translateX(-${getOffset(current) - dragDelta}px)`;
        }
        function onEnd() {
          if (!isDragging) return;
          isDragging = false;
          const threshold = viewport.offsetWidth * 0.12;
          if (dragDelta < -threshold) goTo(current + 1);
          else if (dragDelta > threshold) goTo(current - 1);
          else goTo(current);
          resetAuto();
        }

        viewport.addEventListener('mousedown',  (e:any) => onStart(e.clientX));
        viewport.addEventListener('mousemove',  (e:any) => onMove(e.clientX));
        viewport.addEventListener('mouseup',    onEnd);
        viewport.addEventListener('mouseleave', (e:any) => { if (isDragging) onEnd(); });
        viewport.addEventListener('touchstart', (e:any) => onStart(e.touches[0].clientX), { passive: true });
        viewport.addEventListener('touchmove',  (e:any) => onMove(e.touches[0].clientX),  { passive: true });
        viewport.addEventListener('touchend',   onEnd);

        /* ── Init & resize ── */
        buildDots();
        goTo(0, true);
        startAuto();

        let resizeTimer:any;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(() => {
            buildDots();
            goTo(Math.min(current, Math.max(0, total - visibleCount())), true);
          }, 120);
        });
      })();
    </script>
  </body>
</html>